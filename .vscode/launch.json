{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Test (attach to testhost)",
      "type": "coreclr",
      "request": "attach",
      "processName": "testhost",
      "preLaunchTask": "test-wait-for-debugger"
    },
    {
      "name": ".NET Core Attach",
      "type": "coreclr",
      "request": "attach",
      "processName": "testhost"
    }
  ],
  "inputs": [
    {
      "id": "testFilter",
      "type": "promptString",
      "description": "xUnit filter expression",
      "default": "FullyQualifiedName~RollupEngineTests.Add_AppliesConfiguredDimensionsAndMetrics"
    }
  ]
}
